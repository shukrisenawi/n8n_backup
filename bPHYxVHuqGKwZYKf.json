          "jsCode": "const now = new Date();\n\n// Format YYYY-MM-DD\nlet tarikh = now.toISOString().split(\"T\")[0];\nconst options = { timeZone: \"Asia/Kuala_Lumpur\" };\nconst year = now.toLocaleString(\"en-GB\", { ...options, year: \"numeric\" });\nconst month = now.toLocaleString(\"en-GB\", { ...options, month: \"2-digit\" });\nconst day = now.toLocaleString(\"en-GB\", { ...options, day: \"2-digit\" });\n\nconst tarikh_format = `${day}-${month}-${year}`;\ntarikh =  `${year}-${month}-${day}`;\n\nconst cek_tarikh_hari_jadi = `${month}-${day}`;\nconst hari_jadi = $input.first().json.tarikh_lahir.slice(5);\n\nlet ok = false;\n\nif(cek_tarikh_hari_jadi==hari_jadi)\n{\n  ok = true;\n}\n\nreturn {\n  ok,\n  tarikh,\n  tarikh_format\n};"
        },
