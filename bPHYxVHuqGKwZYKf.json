          "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n   item.json.message = $('Loop Over Items1').first().json.avatar_url+`PASTI Kawasan Sik mengucapkan Selamat Hari Jadi kepada `+$('Loop Over Items1').first().json.nama+`. Semoga panjang umur dalam keberkatan dan dimurahkan rezeki.`;\n  item.json.sessionId = \"masjid_session\";\n  item.json.group = 'default';\n}\n\nreturn $input.all();"
